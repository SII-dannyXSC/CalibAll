<?xml version="1.0"?>
<!-- 由 mujoco_menagerie ufactory_xarm7/xarm7.xml 手工转换（MuJoCo quat 为 w x y z）。
     mesh 使用 package://ufactory_xarm7/assets/...（需将本目录作为 ROS 包或等价映射 share/ufactory_xarm7）。
     来源: https://github.com/google-deepmind/mujoco_menagerie/tree/main/ufactory_xarm7 -->
<robot name="xarm7">
  <!-- rpy 由 scipy Rotation(wxyz)->euler('xyz') 与 MJCF 中 body pos 对齐 -->
  <!-- 根连杆为 link_base（已去掉原 MJCF 里 world 与底座之间的 0.12m 垫高） -->

  <link name="link_base">
    <visual>
      <geometry><mesh filename="package://ufactory_xarm7/assets/link_base.stl"/></geometry>
      <material name="white"><color rgba="1 1 1 1"/></material>
    </visual>
    <collision>
      <geometry><mesh filename="package://ufactory_xarm7/assets/link_base.stl"/></geometry>
    </collision>
    <inertial>
      <origin xyz="-0.021131 -0.0016302 0.056488" rpy="0 0 0"/>
      <mass value="0.88556"/>
      <inertia ixx="0.00382023" ixy="0" ixz="0" iyy="0.00335282" iyz="0" izz="0.00167725"/>
    </inertial>
  </link>

  <joint name="joint1" type="revolute">
    <parent link="link_base"/>
    <child link="link1"/>
    <origin xyz="0 0 0.267" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.28319" upper="6.28319" effort="50" velocity="10"/>
  </joint>
  <link name="link1">
    <visual>
      <geometry><mesh filename="package://ufactory_xarm7/assets/link1.stl"/></geometry>
      <material name="white"><color rgba="1 1 1 1"/></material>
    </visual>
    <collision><geometry><mesh filename="package://ufactory_xarm7/assets/link1.stl"/></geometry></collision>
    <inertial>
      <origin xyz="-0.0002 0.02905 -0.01233" rpy="0 0 0"/>
      <mass value="2.382"/>
      <inertia ixx="0.00569127" ixy="0" ixz="0" iyy="0.00533384" iyz="0" izz="0.00293865"/>
    </inertial>
  </link>

  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0" rpy="-1.5707963267948966 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.059" upper="2.0944" effort="50" velocity="10"/>
  </joint>
  <link name="link2">
    <visual>
      <geometry><mesh filename="package://ufactory_xarm7/assets/link2.stl"/></geometry>
      <material name="white"><color rgba="1 1 1 1"/></material>
    </visual>
    <collision><geometry><mesh filename="package://ufactory_xarm7/assets/link2.stl"/></geometry></collision>
    <inertial>
      <origin xyz="0.00022 -0.12856 0.01735" rpy="0 0 0"/>
      <mass value="1.869"/>
      <inertia ixx="0.00959898" ixy="0" ixz="0" iyy="0.00937717" iyz="0" izz="0.00201315"/>
    </inertial>
  </link>

  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 -0.293 0" rpy="1.5707963267948966 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.28319" upper="6.28319" effort="30" velocity="10"/>
  </joint>
  <link name="link3">
    <visual>
      <geometry><mesh filename="package://ufactory_xarm7/assets/link3.stl"/></geometry>
      <material name="white"><color rgba="1 1 1 1"/></material>
    </visual>
    <collision><geometry><mesh filename="package://ufactory_xarm7/assets/link3.stl"/></geometry></collision>
    <inertial>
      <origin xyz="0.0466 -0.02463 -0.00768" rpy="0 0 0"/>
      <mass value="1.6383"/>
      <inertia ixx="0.00351721" ixy="0" ixz="0" iyy="0.00294089" iyz="0" izz="0.00195868"/>
    </inertial>
  </link>

  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0.0525 0 0" rpy="1.5707963267948966 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.19198" upper="3.927" effort="30" velocity="10"/>
  </joint>
  <link name="link4">
    <visual>
      <geometry><mesh filename="package://ufactory_xarm7/assets/link4.stl"/></geometry>
      <material name="white"><color rgba="1 1 1 1"/></material>
    </visual>
    <collision><geometry><mesh filename="package://ufactory_xarm7/assets/link4.stl"/></geometry></collision>
    <inertial>
      <origin xyz="0.07047 -0.11575 0.012" rpy="0 0 0"/>
      <mass value="1.7269"/>
      <inertia ixx="0.00657137" ixy="0" ixz="0" iyy="0.00647948" iyz="0" izz="0.00186763"/>
    </inertial>
  </link>

  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0.0775 -0.3425 0" rpy="1.5707963267948966 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.28319" upper="6.28319" effort="30" velocity="10"/>
  </joint>
  <link name="link5">
    <visual>
      <geometry><mesh filename="package://ufactory_xarm7/assets/link5.stl"/></geometry>
      <material name="white"><color rgba="1 1 1 1"/></material>
    </visual>
    <collision><geometry><mesh filename="package://ufactory_xarm7/assets/link5.stl"/></geometry></collision>
    <inertial>
      <origin xyz="-0.00032 0.01604 -0.026" rpy="0 0 0"/>
      <mass value="1.3203"/>
      <inertia ixx="0.00534729" ixy="0" ixz="0" iyy="0.00499076" iyz="0" izz="0.0013489"/>
    </inertial>
  </link>

  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0 0 0" rpy="1.5707963267948966 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.69297" upper="3.14159" effort="20" velocity="10"/>
  </joint>
  <link name="link6">
    <visual>
      <geometry><mesh filename="package://ufactory_xarm7/assets/link6.stl"/></geometry>
      <material name="white"><color rgba="1 1 1 1"/></material>
    </visual>
    <collision><geometry><mesh filename="package://ufactory_xarm7/assets/link6.stl"/></geometry></collision>
    <inertial>
      <origin xyz="0.06469 0.03278 0.02141" rpy="0 0 0"/>
      <mass value="1.325"/>
      <inertia ixx="0.00245421" ixy="0" ixz="0" iyy="0.00221646" iyz="0" izz="0.00107273"/>
    </inertial>
  </link>

  <joint name="joint7" type="revolute">
    <parent link="link6"/>
    <child link="link7"/>
    <origin xyz="0.076 0.097 0" rpy="-1.5707963267948966 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.28319" upper="6.28319" effort="20" velocity="10"/>
  </joint>
  <link name="link7">
    <visual>
      <geometry><mesh filename="package://ufactory_xarm7/assets/end_tool.stl"/></geometry>
      <material name="gray"><color rgba="0.753 0.753 0.753 1"/></material>
    </visual>
    <collision><geometry><mesh filename="package://ufactory_xarm7/assets/end_tool.stl"/></geometry></collision>
    <inertial>
      <origin xyz="0 -0.00677 -0.01098" rpy="0 0 0"/>
      <mass value="0.17"/>
      <inertia ixx="0.000132176" ixy="0" ixz="0" iyy="9.3e-05" iyz="0" izz="5.85236e-05"/>
    </inertial>
  </link>

  <joint name="joint_gripper_base" type="fixed">
    <parent link="link7"/>
    <child link="xarm_gripper_base_link"/>
    <origin xyz="0 0 0" rpy="0 0 3.141592653589793"/>
  </joint>
  <link name="xarm_gripper_base_link">
    <visual>
      <geometry><mesh filename="package://ufactory_xarm7/assets/base_link.stl"/></geometry>
      <material name="black"><color rgba="0.149 0.149 0.149 1"/></material>
    </visual>
    <collision><geometry><mesh filename="package://ufactory_xarm7/assets/base_link.stl"/></geometry></collision>
    <inertial>
      <origin xyz="-0.00065489 -0.0018497 0.048028" rpy="0 0 0"/>
      <mass value="0.54156"/>
      <inertia ixx="0.000471093" ixy="0" ixz="0" iyy="0.000332307" iyz="0" izz="0.000254799"/>
    </inertial>
  </link>

  <!-- 与 MJCF equality joint 一致：right_driver 跟随 left_driver -->
  <joint name="left_driver_joint" type="prismatic">
    <parent link="xarm_gripper_base_link"/>
    <child link="left_outer_knuckle"/>
    <origin xyz="0 0.035 0.059098" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.85" effort="50" velocity="2"/>
  </joint>
  <link name="left_outer_knuckle">
    <visual>
      <geometry><mesh filename="package://ufactory_xarm7/assets/left_outer_knuckle.stl"/></geometry>
      <material name="black"><color rgba="0.149 0.149 0.149 1"/></material>
    </visual>
    <collision><geometry><mesh filename="package://ufactory_xarm7/assets/left_outer_knuckle.stl"/></geometry></collision>
    <inertial>
      <origin xyz="0 0.021559 0.015181" rpy="0 0 0"/>
      <mass value="0.033618"/>
      <inertia ixx="1.9111e-05" ixy="0" ixz="0" iyy="1.79089e-05" iyz="0" izz="1.90167e-06"/>
    </inertial>
  </link>

  <joint name="left_finger_joint" type="revolute">
    <parent link="left_outer_knuckle"/>
    <child link="left_finger"/>
    <origin xyz="0 0.035465 0.042039" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0" upper="0.85" effort="10" velocity="2"/>
  </joint>
  <link name="left_finger">
    <visual>
      <geometry><mesh filename="package://ufactory_xarm7/assets/left_finger.stl"/></geometry>
      <material name="black"><color rgba="0.149 0.149 0.149 1"/></material>
    </visual>
    <collision><geometry><mesh filename="package://ufactory_xarm7/assets/left_finger.stl"/></geometry></collision>
    <inertial>
      <origin xyz="0 -0.016413 0.029258" rpy="0 0 0"/>
      <mass value="0.048304"/>
      <inertia ixx="1.88037e-05" ixy="0" ixz="0" iyy="1.7493e-05" iyz="0" izz="3.56792e-06"/>
    </inertial>
  </link>

  <joint name="right_driver_joint" type="prismatic">
    <parent link="xarm_gripper_base_link"/>
    <child link="right_outer_knuckle"/>
    <origin xyz="0 -0.035 0.059098" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0" upper="0.85" effort="50" velocity="2"/>
    <mimic joint="left_driver_joint" multiplier="1" offset="0"/>
  </joint>
  <link name="right_outer_knuckle">
    <visual>
      <geometry><mesh filename="package://ufactory_xarm7/assets/right_outer_knuckle.stl"/></geometry>
      <material name="black"><color rgba="0.149 0.149 0.149 1"/></material>
    </visual>
    <collision><geometry><mesh filename="package://ufactory_xarm7/assets/right_outer_knuckle.stl"/></geometry></collision>
    <inertial>
      <origin xyz="0 -0.021559 0.015181" rpy="0 0 0"/>
      <mass value="0.033618"/>
      <inertia ixx="1.9111e-05" ixy="0" ixz="0" iyy="1.79089e-05" iyz="0" izz="1.90167e-06"/>
    </inertial>
  </link>

  <joint name="right_finger_joint" type="revolute">
    <parent link="right_outer_knuckle"/>
    <child link="right_finger"/>
    <origin xyz="0 -0.035465 0.042039" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="0.85" effort="10" velocity="2"/>
  </joint>
  <link name="right_finger">
    <visual>
      <geometry><mesh filename="package://ufactory_xarm7/assets/right_finger.stl"/></geometry>
      <material name="black"><color rgba="0.149 0.149 0.149 1"/></material>
    </visual>
    <collision><geometry><mesh filename="package://ufactory_xarm7/assets/right_finger.stl"/></geometry></collision>
    <inertial>
      <origin xyz="0 0.016413 0.029258" rpy="0 0 0"/>
      <mass value="0.048304"/>
      <inertia ixx="1.88038e-05" ixy="0" ixz="0" iyy="1.7493e-05" iyz="0" izz="3.56779e-06"/>
    </inertial>
  </link>

  <!-- MJCF 中 inner knuckle 为弹簧/闭链；URDF 用 fixed 近似，仅保留几何 -->
  <joint name="left_inner_knuckle_fixed" type="fixed">
    <parent link="xarm_gripper_base_link"/>
    <child link="left_inner_knuckle"/>
    <origin xyz="0 0.02 0.074098" rpy="0 0 0"/>
  </joint>
  <link name="left_inner_knuckle">
    <visual>
      <geometry><mesh filename="package://ufactory_xarm7/assets/left_inner_knuckle.stl"/></geometry>
      <material name="black"><color rgba="0.149 0.149 0.149 1"/></material>
    </visual>
    <collision><geometry><mesh filename="package://ufactory_xarm7/assets/left_inner_knuckle.stl"/></geometry></collision>
    <inertial>
      <origin xyz="0 0.0220468 0.0261335" rpy="0 0 0"/>
      <mass value="0.0230126"/>
      <inertia ixx="8.34216e-06" ixy="0" ixz="0" iyy="6.0949e-06" iyz="0" izz="2.75601e-06"/>
    </inertial>
  </link>

  <joint name="right_inner_knuckle_fixed" type="fixed">
    <parent link="xarm_gripper_base_link"/>
    <child link="right_inner_knuckle"/>
    <origin xyz="0 -0.02 0.074098" rpy="0 0 0"/>
  </joint>
  <link name="right_inner_knuckle">
    <visual>
      <geometry><mesh filename="package://ufactory_xarm7/assets/right_inner_knuckle.stl"/></geometry>
      <material name="black"><color rgba="0.149 0.149 0.149 1"/></material>
    </visual>
    <collision><geometry><mesh filename="package://ufactory_xarm7/assets/right_inner_knuckle.stl"/></geometry></collision>
    <inertial>
      <origin xyz="0 -0.022047 0.026133" rpy="0 0 0"/>
      <mass value="0.023013"/>
      <inertia ixx="8.34209e-06" ixy="0" ixz="0" iyy="6.0949e-06" iyz="0" izz="2.75601e-06"/>
    </inertial>
  </link>

  <!-- 对应 MJCF site link_tcp: 相对 xarm_gripper_base_link -->
  <link name="link_tcp"/>
  <joint name="link_tcp_fixed" type="fixed">
    <parent link="xarm_gripper_base_link"/>
    <child link="link_tcp"/>
    <origin xyz="0 0 0.172" rpy="0 0 0"/>
  </joint>
</robot>
